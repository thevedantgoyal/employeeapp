# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api
# PostgreSQL
DATABASE_URL=postgresql://postgres:vedant123@localhost:5432/cachetask
# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# First admin setup (only when no admins exist)
FIRST_ADMIN_SETUP_CODE=FIRST_ADMIN_SETUP_2024

# Microsoft Azure AD (Entra ID) SSO — optional
# Register app at portal.azure.com → Azure Active Directory → App registrations → New registration
# Add redirect URI (e.g. http://localhost:5173/auth for SPA). Copy Client ID and Tenant ID here.
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=common

# Optional: base URL for file links (e.g. https://api.example.com)
FILE_BASE_URL=http://localhost:4000

# Face verification (attendance) — AI Vision
# Required: one of the following (never expose to frontend)
# - LOVABLE_API_KEY=sk_... (for Lovable AI gateway)
# - FACE_VERIFICATION_AI_API_KEY=AIza... (Google Gemini key from https://aistudio.google.com/app/apikey) — uses Gemini API directly
# - FACE_VERIFICATION_AI_API_KEY=sk_... (for Lovable/OpenAI-style gateway)
# Optional when using Gemini: FACE_VERIFICATION_GEMINI_MODEL=gemini-2.5-flash (default)
# Optional: FACE_VERIFICATION_AI_GATEWAY_URL (only for sk_ keys; ignored for AIza keys)
# FACE_VERIFICATION_AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1/chat/completions
# FACE_VERIFICATION_AI_MODEL=google/gemini-2.5-flash
# FACE_VERIFICATION_AI_TIMEOUT_MS=20000
# FACE_VERIFICATION_CONFIDENCE_THRESHOLD=75
# FACE_VERIFICATION_MAX_RETRIES=3
# FACE_VERIFICATION_WINDOW_MS=900000
# Set your key in .env only (do not commit real keys). Use AIza... for Google Gemini or sk_... for Lovable.
# FACE_VERIFICATION_AI_API_KEY=
# FACE_VERIFICATION_GEMINI_MODEL=gemini-2.5-flash
FACE_VERIFICATION_AI_TIMEOUT_MS=20000
FACE_VERIFICATION_CONFIDENCE_THRESHOLD=75
FACE_VERIFICATION_AI_MODEL=google/gemini-2.5-flash
FACE_VERIFICATION_MAX_RETRIES=3
FACE_VERIFICATION_WINDOW_MS=900000