# Vite — variables must be prefixed with VITE_ to be exposed to the client.
#
# API base URL (must include the /api prefix used by the backend).
# - Same-origin production (nginx proxies /api to Node): leave unset; build uses /api.
# - Split domains (SPA on app.example.com, API on api.example.com):
#   VITE_API_URL=https://api.example.com/api
#
# VITE_API_URL=
