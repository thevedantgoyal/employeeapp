# Backend API (Node.js + PostgreSQL). Frontend uses this for all API calls.
# Run the backend with: cd backend && npm run dev
VITE_API_URL=http://localhost:4000/api

# Microsoft SSO (optional). Same Client ID as backend AZURE_CLIENT_ID.
# Must match a Redirect URI in Azure (e.g. http://localhost:3000/auth/callback/microsoft).
# VITE_AZURE_CLIENT_ID=
# VITE_AZURE_TENANT_ID=common
# VITE_AZURE_REDIRECT_URI=http://localhost:3000/auth/callback/microsoft

# Organization name shown on onboarding welcome screen
# VITE_ORGANIZATION_NAME=MIRROR
